# Thorium Browser VNC Server Configuration
# Copy this file to .env and customize as needed

# VNC Configuration
VNC_DISPLAY=:1
VNC_GEOMETRY=1280x960
VNC_DEPTH=24
VNC_PASSWORD=vnc

# Chromium/Browser Configuration
CHROMIUM_FLAGS=--no-sandbox --disable-gpu --disable-dev-shm-usage --remote-debugging-port=9222

# Display Configuration
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=960
DISPLAY_DEPTH=24

# Container Restart Policy
RESTART_POLICY=unless-stopped

# Network Settings
ENABLE_AUDIO=true
ENABLE_DBUS=true

# Performance Tuning
DISABLE_DEV_SHM=true
DISABLE_GPU=true

# Security
ENABLE_VNC_AUTH=true
VNC_AUTH_TYPE=VncAuth
